<!DOCTYPE html>
<html lang="es">
<head>
    <meta property="og:title" content="Deja de Pagarle a LUMA | Energía Solar Puerto Rico" />
    <meta property="og:description" content="Soluciones de Energia Solar en Puerto Rico" />
    <meta property="og:image" content="https://github.com/rafael33pr/astro-blog-starter-template/blob/main/src/styles/rafael_solar.jpg" />
    <meta property="og:url" content="https://sinlumapr.com" />
    <meta property="og:type" content="website" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deja de Pagarle a LUMA | Energía Solar Puerto Rico</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'Inter', sans-serif;
            
            /* PALETA SOLAR AMARILLA/NARANJA */
            --solar-yellow: #fbbf24;      /* Amarillo dorado */
            --solar-orange: #f97316;      /* Naranja fuerte */
            --solar-dark: #ea580c;        /* Naranja oscuro */
            --solar-light: #fde68a;       /* Amarillo claro */
            --sun-gold: #f59e0b;          /* Dorado sol */
            
            --dark-bg: #431407;           /* Marrón oscuro para contraste */
            --light-bg: #fffbeb;          /* Crema amarillo claro */
            --whatsapp: #25d366;
        }

        body {
            font-family: var(--font-body);
            line-height: 1.6;
            color: #431407;
            background: #fff;
        }

        h1, h2, h3, .price-tag, .stat-number, .savings-amount {
            font-family: var(--font-display);
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        /* Urgency Bar - Gradiente amarillo/naranja */
        .urgency-bar {
            background: linear-gradient(90deg, var(--solar-dark), var(--solar-orange));
            color: white;
            text-align: center;
            padding: 1rem;
            font-family: var(--font-display);
            font-weight: 500;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* HERO - Gradiente amarillo/naranja puro */
        .hero {
            background: linear-gradient(135deg, var(--sun-gold) 0%, var(--solar-yellow) 30%, var(--solar-orange) 70%, var(--solar-dark) 100%);
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }

        /* Efecto sol brillante */
        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 70%);
            animation: pulse 4s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.6; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        .hero-content {
            max-width: 900px;
            position: relative;
            z-index: 2;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 0.9;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .hero h1 span {
            color: #fffbeb;
            display: block;
            font-size: 5rem;
            font-weight: 700;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.3);
        }

        .hero-subtitle {
            font-family: var(--font-body);
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            font-weight: 400;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin: 2.5rem 0;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            padding: 1.5rem;
            border-radius: 15px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .stat-number {
            font-size: 3.5rem;
            color: #fffbeb;
            display: block;
            line-height: 1;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .stat-label {
            font-family: var(--font-body);
            font-size: 0.9rem;
            opacity: 0.95;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cta-button {
            display: inline-block;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: linear-gradient(135deg, var(--solar-dark), var(--solar-orange));
            color: white;
            padding: 1.3rem 3rem;
            font-size: 1.1rem;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(234,88,12,0.4);
            margin: 0.5rem;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .cta-button:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 30px rgba(234,88,12,0.6);
        }

        .whatsapp-btn {
            background: linear-gradient(135deg, var(--whatsapp), #128c7e);
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
        }

        .whatsapp-btn:hover {
            box-shadow: 0 6px 25px rgba(37,211,102,0.6);
        }

        /* PROBLEMA - Fondo oscuro cálido */
        .problem {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: #fffbeb;
            text-align: center;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2.8rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .highlight-box {
            background: rgba(251,191,36,0.2);
            border: 2px solid var(--solar-yellow);
            border-radius: 15px;
            padding: 2.5rem;
            margin: 2rem 0;
        }

        .big-number {
            font-size: 5rem;
            color: var(--solar-yellow);
            display: block;
            line-height: 1;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        /* COMPARACIÓN - Fondo crema */
        .comparison {
            padding: 5rem 2rem;
            background: var(--light-bg);
        }

        .comparison-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .comparison-card {
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            display: flex;
            flex-direction: column;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .luma-card {
            border: 3px solid #dc2626;
        }

        .finance-card {
            border: 3px solid var(--sun-gold);
        }

        .solar-card {
            border: 3px solid #16a34a;
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 1.3rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .luma-card .card-title { color: #dc2626; }
        .finance-card .card-title { color: #b45309; }
        .solar-card .card-title { color: #16a34a; }

        .price-tag {
            font-size: 3rem;
            margin: 1rem 0;
            line-height: 1;
        }

        .luma-card .price-tag { color: #dc2626; }
        .finance-card .price-tag { color: #b45309; }
        .solar-card .price-tag { color: #16a34a; }

        .monthly-tag {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .comparison-card hr {
            margin: 1rem 0;
            border: none;
            height: 2px;
        }

        .luma-card hr { background: #dc2626; }
        .finance-card hr { background: var(--sun-gold); }
        .solar-card hr { background: #16a34a; }

        .comparison-card p {
            font-family: var(--font-body);
            margin: 0.5rem 0;
            font-size: 0.95rem;
        }

        .feature-list {
            text-align: left;
            margin: 1rem 0;
            flex-grow: 1;
        }

        .feature-list li {
            list-style: none;
            padding: 0.3rem 0;
            padding-left: 1.5rem;
            position: relative;
            font-size: 0.9rem;
        }

        .luma-card .feature-list li::before { content: '❌'; position: absolute; left: 0; color: #dc2626; }
        .finance-card .feature-list li::before { content: '⚡'; position: absolute; left: 0; color: var(--sun-gold); }
        .solar-card .feature-list li::before { content: '✅'; position: absolute; left: 0; color: #16a34a; }

        .total-25 {
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            margin-top: auto;
            padding-top: 1rem;
        }

        .luma-card .total-25 { color: #dc2626; }
        .finance-card .total-25 { color: #b45309; }
        .solar-card .total-25 { color: #16a34a; }

        /* CAJA DE AHORRO - Gradiente solar */
        .savings-box {
            background: linear-gradient(135deg, var(--solar-orange), var(--solar-dark));
            color: white;
            padding: 2.5rem;
            border-radius: 15px;
            text-align: center;
            margin-top: 2rem;
            box-shadow: 0 10px 30px rgba(234,88,12,0.3);
        }

        .savings-box p:first-child {
            font-family: var(--font-display);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 1rem;
        }

        .savings-amount {
            font-size: 4rem;
            line-height: 1;
            margin: 1rem 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        /* SOBRE MÍ - Fondo amarillo claro */
        .about {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
        }

        .about-container {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 3rem;
            align-items: center;
        }

        .about-image {
            position: relative;
        }

        .about-image img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(234,88,12,0.2);
            border: 4px solid white;
        }

        .about-badge {
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, var(--solar-orange), var(--solar-dark));
            color: white;
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(234,88,12,0.4);
            white-space: nowrap;
        }

        .about-content h2 {
            font-size: 2.5rem;
            color: var(--solar-dark);
            margin-bottom: 0.5rem;
        }

        .about-name {
            font-family: var(--font-display);
            font-size: 2rem;
            color: var(--solar-orange);
            margin-bottom: 1rem;
        }

        .about-role {
            font-family: var(--font-body);
            font-size: 1.1rem;
            color: #92400e;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .about-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #78350f;
            margin-bottom: 1.5rem;
        }

        .about-text strong {
            color: var(--solar-dark);
        }

        .about-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--whatsapp);
            color: white;
            padding: 1rem 2rem;
            border-radius: 50px;
            text-decoration: none;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: transform 0.3s;
            margin-top: 1rem;
        }

        .about-cta:hover {
            transform: scale(1.05);
        }

        .trust-badges {
            display: flex;
            gap: 2rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .trust-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: #92400e;
        }

        .trust-badge span {
            font-size: 1.5rem;
        }

        @media (max-width: 768px) {
            .about-container {
                grid-template-columns: 1fr;
                text-align: center;
            }
            
            .about-image {
                max-width: 280px;
                margin: 0 auto;
            }
            
            .trust-badges {
                justify-content: center;
            }
        }

        /* CÓMO FUNCIONA - Fondo amarillo muy claro */
        .how-it-works {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, #fffbeb 0%, #fef9c3 100%);
        }

        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .step {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(234,88,12,0.1);
            border: 2px solid var(--solar-light);
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--solar-orange), var(--solar-dark));
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 auto 1rem;
            box-shadow: 0 4px 10px rgba(234,88,12,0.3);
        }

        .step h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            color: var(--solar-dark);
        }

        .step p {
            font-family: var(--font-body);
            color: #78350f;
        }

        /* TESTIMONIAL - Fondo oscuro cálido */
        .testimonial {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: #fffbeb;
            text-align: center;
        }

        .testimonial-text {
            font-family: 'Merriweather', serif;
            font-size: 1.4rem;
            font-style: italic;
            line-height: 1.8;
            max-width: 800px;
            margin: 0 auto 1.5rem;
        }

        .testimonial-author {
            font-family: var(--font-display);
            color: var(--solar-yellow);
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* CTA FINAL - Gradiente solar intenso */
        .final-cta {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, var(--sun-gold) 0%, var(--solar-orange) 50%, var(--solar-dark) 100%);
            color: white;
            text-align: center;
        }

        .final-cta h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .final-cta p {
            font-family: var(--font-body);
            font-size: 1.2rem;
            margin-bottom: 1rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .whatsapp-big {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: white;
            color: var(--solar-dark);
            padding: 1.5rem 3rem;
            font-size: 1.2rem;
            text-decoration: none;
            border-radius: 50px;
            margin-top: 2rem;
            transition: transform 0.3s;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .whatsapp-big:hover {
            transform: scale(1.05);
        }

        /* FOOTER - Marrón oscuro */
        footer {
            background: #431407;
            color: #fde68a;
            text-align: center;
            padding: 2rem;
            font-family: var(--font-body);
        }

        @media (max-width: 900px) {
            .comparison-grid { grid-template-columns: 1fr; }
            .hero h1 { font-size: 2.5rem; }
            .hero h1 span { font-size: 3rem; }
            .stat-number { font-size: 2.5rem; }
            .big-number, .savings-amount { font-size: 3rem; }
            .section-title { font-size: 2rem; }
            .price-tag { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <div class="urgency-bar">
        ⚡ Rafael Santiago - Pura Energía ⚡
    </div>

