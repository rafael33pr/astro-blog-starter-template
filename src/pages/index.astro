<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deja de Pagarle a LUMA | Energía Solar Puerto Rico</title>
    
    <!-- NUEVAS FUENTES DE IMPACTO -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* FUENTES PRINCIPALES */
        :root {
            --font-display: 'Space Grotesk', sans-serif;  /* Títulos impacto */
            --font-body: 'Inter', sans-serif;              /* Lectura fácil */
            
            --solar-orange: #ff6b35;
            --solar-yellow: #f7c948;
            --sky-blue: #0ea5e9;
            --deep-blue: #0369a1;
            --dark-bg: #0f172a;
            --light-bg: #f0f9ff;
            --whatsapp: #25d366;
        }

        body {
            font-family: var(--font-body);
            line-height: 1.6;
            color: #1a202c;
            background: #fff;
        }

        /* IMPACTO TIPOGRÁFICO */
        h1, h2, h3, .price-tag, .stat-number, .savings-amount {
            font-family: var(--font-display);
            font-weight: 700;
            letter-spacing: -0.02em; /* Tight para impacto */
        }

        /* Urgency Bar */
        .urgency-bar {
            background: linear-gradient(90deg, var(--solar-orange), #ff8c42);
            color: white;
            text-align: center;
            padding: 1rem;
            font-family: var(--font-display);
            font-weight: 500;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Hero */
        .hero {
            background: linear-gradient(135deg, var(--deep-blue) 0%, var(--sky-blue) 50%, var(--solar-yellow) 100%);
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 2rem;
        }

        .hero-content {
            max-width: 900px;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 0.9;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
        }

        .hero h1 span {
            color: var(--solar-yellow);
            display: block;
            font-size: 5rem;
            font-weight: 700;
        }

        .hero-subtitle {
            font-family: var(--font-body);
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            font-weight: 400;
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin: 2.5rem 0;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 3.5rem;
            color: var(--solar-yellow);
            display: block;
            line-height: 1;
        }

        .stat-label {
            font-family: var(--font-body);
            font-size: 0.9rem;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cta-button {
            display: inline-block;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 1.3rem 3rem;
            font-size: 1.1rem;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(255,107,53,0.4);
            margin: 0.5rem;
        }

        .cta-button:hover {
            transform: translateY(-3px) scale(1.05);
        }

        .whatsapp-btn {
            background: linear-gradient(135deg, var(--whatsapp), #128c7e);
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
        }

        .whatsapp-btn:hover {
            box-shadow: 0 6px 25px rgba(37,211,102,0.6);
        }

        /* Problem Section */
        .problem {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 3rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .highlight-box {
            background: rgba(255,107,53,0.2);
            border: 2px solid var(--solar-orange);
            border-radius: 15px;
            padding: 2.5rem;
            margin: 2rem 0;
        }

        .big-number {
            font-size: 5rem;
            color: var(--solar-orange);
            display: block;
            line-height: 1;
        }

        .highlight-box p {
            font-family: var(--font-body);
            font-size: 1.2rem;
            margin-top: 0.5rem;
        }

        /* Comparison Section */
        .comparison {
            padding: 5rem 2rem;
            background: white;
        }

        .comparison-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .comparison-card {
            padding: 2.5rem;
            border-radius: 15px;
            text-align: center;
        }

        .luma-card {
            background: #fee2e2;
            border: 3px solid #dc2626;
        }

        .solar-card {
            background: #dcfce7;
            border: 3px solid #16a34a;
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .luma-card .card-title { color: #dc2626; }
        .solar-card .card-title { color: #16a34a; }

        .price-tag {
            font-size: 4rem;
            margin: 1.5rem 0;
            line-height: 1;
        }

        .luma-card .price-tag { color: #dc2626; }
        .solar-card .price-tag { color: #16a34a; }

        .comparison-card p {
            font-family: var(--font-body);
            margin: 0.5rem 0;
        }

        .savings-box {
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 2.5rem;
            border-radius: 15px;
            text-align: center;
            margin-top: 2rem;
        }

        .savings-box p:first-child {
            font-family: var(--font-display);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 1rem;
        }

        .savings-amount {
            font-size: 5rem;
            line-height: 1;
            margin: 1rem 0;
        }

        /* How It Works */
        .how-it-works {
            padding: 5rem 2rem;
            background: var(--light-bg);
        }

        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .step {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: var(--deep-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 auto 1rem;
        }

        .step h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .step p {
            font-family: var(--font-body);
            color: #64748b;
        }

        /* Testimonial */
        .testimonial {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .testimonial-text {
            font-family: 'Merriweather', serif;
            font-size: 1.4rem;
            font-style: italic;
            line-height: 1.8;
            max-width: 800px;
            margin: 0 auto 1.5rem;
        }

        .testimonial-author {
            font-family: var(--font-display);
            color: var(--solar-yellow);
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Final CTA */
        .final-cta {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, var(--deep-blue), var(--sky-blue));
            color: white;
            text-align: center;
        }

        .final-cta h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .final-cta p {
            font-family: var(--font-body);
            font-size: 1.2rem;
            margin-bottom: 1rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .whatsapp-big {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: var(--whatsapp);
            color: white;
            padding: 1.5rem 3rem;
            font-size: 1.2rem;
            text-decoration: none;
            border-radius: 50px;
            margin-top: 2rem;
            transition: transform 0.3s;
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
        }

        .whatsapp-big:hover {
            transform: scale(1.05);
        }

        /* Footer */
        footer {
            background: var(--dark-bg);
            color: #94a3b8;
            text-align: center;
            padding: 2rem;
            font-family: var(--font-body);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .hero h1 span { font-size: 3rem; }
            .comparison-grid { grid-template-columns: 1fr; }
            .stat-number { font-size: 2.5rem; }
            .big-number, .savings-amount { font-size: 3.5rem; }
            .section-title { font-size: 2rem; }
        }
    </style>
</head>
<body>

