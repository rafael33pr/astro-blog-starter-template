            align-items: center;
            gap: 1rem;
            background: var(--whatsapp);
            color: white;
            padding: 1.5rem 3rem;
            font-size: 1.3rem;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 700;
            margin-top: 2rem;
            transition: transform 0.3s;
        }

        .whatsapp-big:hover {
