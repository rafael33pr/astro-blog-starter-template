        }

        /* Footer */
        footer {
            background: var(--dark-bg);
            color: #94a3b8;
            text-align: center;
            padding: 2rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
            .hero h1 span { font-size: 2.5rem; }
            .comparison-grid { grid-template-columns: 1fr; }
            .hero-stats { gap: 1.5rem; }
            .big-number { font-size: 3rem; }
        }
