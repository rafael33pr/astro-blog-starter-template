<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deja de Pagarle a LUMA | Energía Solar Puerto Rico</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'Inter', sans-serif;
            --solar-orange: #ff6b35;
            --solar-yellow: #f7c948;
            --sky-blue: #0ea5e9;
            --deep-blue: #0369a1;
            --dark-bg: #0f172a;
            --light-bg: #f0f9ff;
            --whatsapp: #25d366;
        }

        body {
            font-family: var(--font-body);
            line-height: 1.6;
            color: #1a202c;
            background: #fff;
        }

        h1, h2, h3, .price-tag, .stat-number, .savings-amount {
            font-family: var(--font-display);
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .urgency-bar {
            background: linear-gradient(90deg, var(--solar-orange), #ff8c42);
            color: white;
            text-align: center;
            padding: 1rem;
            font-family: var(--font-display);
            font-weight: 500;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .hero {
            background: linear-gradient(135deg, var(--deep-blue) 0%, var(--sky-blue) 50%, var(--solar-yellow) 100%);
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 2rem;
        }

        .hero-content {
            max-width: 900px;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 0.9;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
        }

        .hero h1 span {
            color: var(--solar-yellow);
            display: block;
            font-size: 5rem;
            font-weight: 700;
        }

        .hero-subtitle {
            font-family: var(--font-body);
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            font-weight: 400;
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin: 2.5rem 0;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 3.5rem;
            color: var(--solar-yellow);
            display: block;
            line-height: 1;
        }

        .stat-label {
            font-family: var(--font-body);
            font-size: 0.9rem;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cta-button {
            display: inline-block;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 1.3rem 3rem;
            font-size: 1.1rem;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(255,107,53,0.4);
            margin: 0.5rem;
        }

        .cta-button:hover {
            transform: translateY(-3px) scale(1.05);
        }

        .whatsapp-btn {
            background: linear-gradient(135deg, var(--whatsapp), #128c7e);
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
        }

        .whatsapp-btn:hover {
            box-shadow: 0 6px 25px rgba(37,211,102,0.6);
        }

        .problem {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2.8rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .highlight-box {
            background: rgba(255,107,53,0.2);
            border: 2px solid var(--solar-orange);
            border-radius: 15px;
            padding: 2.5rem;
            margin: 2rem 0;
        }

        .big-number {
            font-size: 5rem;
            color: var(--solar-orange);
            display: block;
            line-height: 1;
        }

        .comparison {
            padding: 5rem 2rem;
            background: white;
        }

        .comparison-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .comparison-card {
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            display: flex;
            flex-direction: column;
        }

        .luma-card {
            background: #fee2e2;
            border: 3px solid #dc2626;
        }

        .finance-card {
            background: #fef3c7;
            border: 3px solid #f59e0b;
        }

        .solar-card {
            background: #dcfce7;
            border: 3px solid #16a34a;
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 1.3rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .luma-card .card-title { color: #dc2626; }
        .finance-card .card-title { color: #b45309; }
        .solar-card .card-title { color: #16a34a; }

        .price-tag {
            font-size: 3rem;
            margin: 1rem 0;
            line-height: 1;
        }

        .luma-card .price-tag { color: #dc2626; }
        .finance-card .price-tag { color: #b45309; }
        .solar-card .price-tag { color: #16a34a; }

        .monthly-tag {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .comparison-card hr {
            margin: 1rem 0;
            border: none;
            height: 2px;
        }

        .luma-card hr { background: #dc2626; }
        .finance-card hr { background: #f59e0b; }
        .solar-card hr { background: #16a34a; }

        .comparison-card p {
            font-family: var(--font-body);
            margin: 0.5rem 0;
            font-size: 0.95rem;
        }

        .feature-list {
            text-align: left;
            margin: 1rem 0;
            flex-grow: 1;
        }

        .feature-list li {
            list-style: none;
            padding: 0.3rem 0;
            padding-left: 1.5rem;
            position: relative;
            font-size: 0.9rem;
        }

        .luma-card .feature-list li::before { content: '❌'; position: absolute; left: 0; color: #dc2626; }
        .finance-card .feature-list li::before { content: '⚡'; position: absolute; left: 0; color: #f59e0b; }
        .solar-card .feature-list li::before { content: '✅'; position: absolute; left: 0; color: #16a34a; }

        .total-25 {
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            margin-top: auto;
            padding-top: 1rem;
        }

        .luma-card .total-25 { color: #dc2626; }
        .finance-card .total-25 { color: #b45309; }
        .solar-card .total-25 { color: #16a34a; }

        .savings-box {
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 2.5rem;
            border-radius: 15px;
            text-align: center;
            margin-top: 2rem;
        }

        .savings-box p:first-child {
            font-family: var(--font-display);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 1rem;
        }

        .savings-amount {
            font-size: 4rem;
            line-height: 1;
            margin: 1rem 0;
        }

        /* SOBRE MÍ - RAFAEL SANTIAGO */
        .about {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }

        .about-container {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 3rem;
            align-items: center;
        }

        .about-image {
            position: relative;
        }

        .about-image img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            border: 4px solid white;
        }

        .about-badge {
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(255,107,53,0.4);
            white-space: nowrap;
        }

        .about-content h2 {
            font-size: 2.5rem;
            color: var(--deep-blue);
            margin-bottom: 0.5rem;
        }

        .about-name {
            font-family: var(--font-display);
            font-size: 2rem;
            color: var(--solar-orange);
            margin-bottom: 1rem;
        }

        .about-role {
            font-family: var(--font-body);
            font-size: 1.1rem;
            color: #64748b;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .about-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #475569;
            margin-bottom: 1.5rem;
        }

        .about-text strong {
            color: var(--deep-blue);
        }

        .about-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--whatsapp);
            color: white;
            padding: 1rem 2rem;
            border-radius: 50px;
            text-decoration: none;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: transform 0.3s;
            margin-top: 1rem;
        }

        .about-cta:hover {
            transform: scale(1.05);
        }

        .trust-badges {
            display: flex;
            gap: 2rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .trust-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: #64748b;
        }

        .trust-badge span {
            font-size: 1.5rem;
        }

        @media (max-width: 768px) {
            .about-container {
                grid-template-columns: 1fr;
                text-align: center;
            }
            
            .about-image {
                max-width: 280px;
                margin: 0 auto;
            }
            
            .trust-badges {
                justify-content: center;
            }
        }

        .how-it-works {
            padding: 5rem 2rem;
            background: var(--light-bg);
        }

        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .step {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: var(--deep-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 auto 1rem;
        }

        .step h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .step p {
            font-family: var(--font-body);
            color: #64748b;
        }

        .testimonial {
            padding: 5rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .testimonial-text {
            font-family: 'Merriweather', serif;
            font-size: 1.4rem;
            font-style: italic;
            line-height: 1.8;
            max-width: 800px;
            margin: 0 auto 1.5rem;
        }

        .testimonial-author {
            font-family: var(--font-display);
            color: var(--solar-yellow);
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .final-cta {
            padding: 5rem 2rem;
            background: linear-gradient(135deg, var(--deep-blue), var(--sky-blue));
            color: white;
            text-align: center;
        }

        .final-cta h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .final-cta p {
            font-family: var(--font-body);
            font-size: 1.2rem;
            margin-bottom: 1rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .whatsapp-big {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            font-family: var(--font-display);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: var(--whatsapp);
            color: white;
            padding: 1.5rem 3rem;
            font-size: 1.2rem;
            text-decoration: none;
            border-radius: 50px;
            margin-top: 2rem;
            transition: transform 0.3s;
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
        }

        .whatsapp-big:hover {
            transform: scale(1.05);
        }

        footer {
            background: var(--dark-bg);
            color: #94a3b8;
            text-align: center;
            padding: 2rem;
            font-family: var(--font-body);
        }

        @media (max-width: 900px) {
            .comparison-grid { grid-template-columns: 1fr; }
            .hero h1 { font-size: 2.5rem; }
            .hero h1 span { font-size: 3rem; }
            .stat-number { font-size: 2.5rem; }
            .big-number, .savings-amount { font-size: 3rem; }
            .section-title { font-size: 2rem; }
            .price-tag { font-size: 2.5rem; }
        }
    </style>
</head>
