        .problem {
            padding: 4rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .highlight-box {
            background: rgba(255,107,53,0.2);
            border: 2px solid var(--solar-orange);
            border-radius: 15px;
            padding: 2rem;
            margin: 2rem 0;
        }

        .big-number {
            font-size: 4rem;
            font-weight: 800;
            color: var(--solar-orange);
            display: block;
        }

        /* Comparison Section */
        .comparison {
            padding: 4rem 2rem;
            background: white;
        }

        .comparison-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .comparison-card {
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
        }

        .luma-card {
            background: #fee2e2;
            border: 2px solid #dc2626;
        }

        .solar-card {
            background: #dcfce7;
            border: 2px solid #16a34a;
        }

        .card-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .luma-card .card-title { color: #dc2626; }
        .solar-card .card-title { color: #16a34a; }

        .price-tag {
            font-size: 3rem;
            font-weight: 800;
            margin: 1rem 0;
        }

        .luma-card .price-tag { color: #dc2626; }
        .solar-card .price-tag { color: #16a34a; }

        .savings-box {
            background: linear-gradient(135deg, var(--solar-orange), #ff8c42);
            color: white;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            margin-top: 2rem;
        }

        .savings-amount {
            font-size: 3.5rem;
            font-weight: 800;
        }

        /* How It Works */
        .how-it-works {
            padding: 4rem 2rem;
            background: var(--light-bg);
        }

        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .step {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .step-number {
            width: 50px;
            height: 50px;
            background: var(--deep-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 auto 1rem;
        }

        /* Testimonial */
        .testimonial {
            padding: 4rem 2rem;
            background: var(--dark-bg);
            color: white;
            text-align: center;
        }

        .testimonial-text {
            font-size: 1.3rem;
            font-style: italic;
            max-width: 700px;
            margin: 0 auto 1rem;
        }

        .testimonial-author {
            color: var(--solar-yellow);
            font-weight: 700;
        }

