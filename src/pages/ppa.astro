    padding: 4rem 0;
}

.pr-alert {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(251,191,36,0.2);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border: 1px solid var(--pe-yellow);
}

.alert-icon {
    font-size: 3rem;
}

.alert-text h4 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--pe-yellow);
    font-weight: 700;
}

.alert-text p {
    opacity: 0.9;
    margin: 0;
    font-weight: 500;
}

.timeline-urgency {
    text-align: center;
}

.timeline-q {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
}

.timeline-options {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
}

.timeline-btn {
    background: rgba(255,255,255,0.1);
    border: 2px solid var(--pe-yellow);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
}

.timeline-btn:hover {
    background: var(--pe-yellow);
    color: var(--pe-dark);
}

.timeline-result {
    font-size: 1.1rem;
    font-weight: 600;
    min-height: 1.5em;
    color: var(--pe-yellow);
}

/* SECCIÓN 7: CTA */
.cta-section {
    background: linear-gradient(135deg, var(--pe-blue) 0%, var(--pe-dark) 100%);
    color: white;
    padding: 4rem 0;
    text-align: center;
}

.cta-section h2 {
    font-size: 1.9rem;
    margin-bottom: 1rem;
    font-weight: 700;
}

.cta-lead {
    font-size: 1.1rem;
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto 2rem;
    font-weight: 500;
}

.mega-cta {
    display: block;
    background: var(--pe-yellow);
    color: var(--pe-dark);
    padding: 1.5rem 2rem;
    border-radius: 12px;
    text-decoration: none;
    max-width: 400px;
    margin: 0 auto 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    transition: transform 0.2s;
}

.mega-cta:hover {
    transform: scale(1.02);
}

.cta-main {
    display: block;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
}

.cta-sub {
    display: block;
    font-size: 0.85rem;
    color: var(--pe-dark);
    opacity: 0.8;
    font-weight: 500;
}

.final-reassurance {
    margin-bottom: 2rem;
}

.final-reassurance p {
    margin: 0.5rem 0;
    font-size: 0.9rem;
    opacity: 0.9;
    font-weight: 500;
}

.micro-copy {
    font-size: 0.7rem;
    opacity: 0.7;
}

.micro-copy a {
    color: var(--pe-yellow);
    text-decoration: underline;
    font-weight: 600;
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .math-showdown {
        grid-template-columns: 1fr;
    }
    
    .vs-center {
        order: -1;
    }
    
    .how-it-works-simple {
        flex-direction: column;
    }
    
    .arrow {
        transform: rotate(90deg);
    }
    
    .problem-section h2 {
        font-size: 1.6rem;
    }
    
    .battery-scenarios {
        grid-template-columns: 1fr;
    }
}
